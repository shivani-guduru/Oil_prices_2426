        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "# Helper function: run ADF + KPSS and print a clean summary table\n",
        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "\n",
        "def run_stationarity_tests(series, series_name=\"Series\"):\n",
        "    \"\"\"\n",
        "    Runs both the Augmented Dickey-Fuller (ADF) and KPSS stationarity tests\n",
        "    on a given time series and prints a formatted summary of results.\n",
        "\n",
        "    Parameters:\n",
        "    -----------\n",
        "    series      : pd.Series  — the time series to test\n",
        "    series_name : str        — label used in the output header\n",
        "\n",
        "    Returns:\n",
        "    --------\n",
        "    dict with keys: 'adf_pvalue', 'kpss_pvalue', 'adf_stationary', 'kpss_stationary'\n",
        "    \"\"\"\n",
        "    print(\"=\" * 60)\n",
        "    print(f\"  STATIONARITY TESTS — {series_name}\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    # ── ADF Test ──────────────────────────────────────────────────────────────\n",
        "    adf_result = adfuller(series.dropna(), autolag='AIC')\n",
        "    adf_stat, adf_p = adf_result[0], adf_result[1]\n",
        "    adf_crits       = adf_result[4]\n",
        "    adf_stationary  = adf_p < 0.05\n",
        "\n",
        "    print(\"\\n  [1] Augmented Dickey-Fuller Test\")\n",
        "    print(f\"      H₀: Series has a unit root (non-stationary)\")\n",
        "    print(f\"      ADF Statistic  : {adf_stat:.4f}\")\n",
        "    print(f\"      p-value        : {adf_p:.6f}  {'← REJECT H₀ → Stationary ' if adf_stationary else '← FAIL TO REJECT H₀ → Non-Stationary '}\")\n",
        "    print(f\"      Critical Values: 1%={adf_crits['1%']:.3f}  5%={adf_crits['5%']:.3f}  10%={adf_crits['10%']:.3f}\")\n",
        "\n",
        "    # ── KPSS Test ─────────────────────────────────────────────────────────────\n",
        "    kpss_result = kpss(series.dropna(), regression='c', nlags='auto')\n",
        "    kpss_stat, kpss_p = kpss_result[0], kpss_result[1]\n",
        "    kpss_crits        = kpss_result[3]\n",
        "    kpss_stationary   = kpss_p > 0.05    # KPSS: large p-value → fail to reject H₀ → stationary\n",
        "\n",
        "    print(\"\\n  [2] KPSS Test\")\n",
        "    print(f\"      H₀: Series is stationary (trend-stationary)\")\n",
        "    print(f\"      KPSS Statistic : {kpss_stat:.4f}\")\n",
        "    print(f\"      p-value        : {kpss_p:.6f}  {'← FAIL TO REJECT H₀ → Stationary ' if kpss_stationary else '← REJECT H₀ → Non-Stationary '}\")\n",
        "    print(f\"      Critical Values: 1%={kpss_crits['1%']:.3f}  5%={kpss_crits['5%']:.3f}  10%={kpss_crits['10%']:.3f}\")\n",
        "\n",
        "    # ── Combined Conclusion ───────────────────────────────────────────────────\n",
