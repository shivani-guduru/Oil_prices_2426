        "            'kpss_stat': kpss_stat, 'kpss_pvalue': kpss_p,\n",
        "            'adf_stationary': adf_stationary, 'kpss_stationary': kpss_stationary}\n",
        "\n",
        "# ─── Test the original (raw) series ──────────────────────────────────────────\n",
        "original_results = run_stationarity_tests(df['price'], \"Original Price Series\")"
