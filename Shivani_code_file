        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "# Prophet Hyperparameter Tuning\n",
        "# Jupyter-compatible version — uses sys.stderr reassignment instead of os.dup2\n",
        "# since Jupyter's IPython kernel wraps stderr as a StringIO (no real fileno)\n",
        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "\n",
        "import logging\n",
        "import sys\n",
        "import io\n",
        "from contextlib import contextmanager\n",
        "\n",
        "# Suppress all Python-level Prophet / Stan / cmdstanpy logs\n",
        "for logger_name in ['prophet', 'cmdstanpy', 'stan', 'cmdstan', 'fbprophet']:\n",
        "    logging.getLogger(logger_name).setLevel(logging.CRITICAL)\n",
        "\n",
        "@contextmanager\n",
        "def suppress_all_output():\n",
        "    \"\"\"\n",
        "    Jupyter-safe context manager that suppresses stderr output by temporarily\n",
        "    replacing sys.stderr with a StringIO sink.\n",
        "\n",
        "    Note: os.dup2() cannot be used in Jupyter because IPython wraps sys.stderr\n",
        "    as a virtual stream with no real OS file descriptor (raises 'fileno' error).\n",
        "    Replacing sys.stderr at the Python object level catches cmdstanpy messages\n",
        "    that are routed through the logging system back to sys.stderr.\n",
        "    \"\"\"\n",
        "    # Capture original streams\n",
        "    original_stderr = sys.stderr\n",
        "    original_stdout = sys.stdout\n",
        "\n",
        "    # Redirect to a black-hole StringIO buffer\n",
        "    sys.stderr = io.StringIO()\n",
        "\n",
        "    try:\n",
        "        yield\n",
        "    finally:\n",
        "        # Always restore — even if an exception occurs inside the block\n",
        "        sys.stderr = original_stderr\n",
        "\n",
        "\n",
        "def tune_prophet_changepoint(prophet_df, cps_values, initial='365 days', period='30 days', horizon='60 days'):\n",
        "    \"\"\"\n",
        "    Tunes Prophet's changepoint_prior_scale parameter via time series cross-validation.\n",
        "\n",
        "    Parameters:\n",
        "    -----------\n",
        "    prophet_df  : DataFrame with 'ds' and 'y' columns\n",
        "    cps_values  : list of changepoint_prior_scale values to test\n",
        "    initial     : str — initial training window. Must exceed longest seasonality\n",
        "                  period (365.25 days) to avoid yearly seasonality warning.\n",
        "    period      : str — spacing between successive CV cutoff dates\n",
        "    horizon     : str — forecast horizon evaluated at each CV cutoff\n",
        "\n",
        "    Returns:\n",
        "    --------\n",
        "    pd.DataFrame sorted ascending by RMSE with columns:\n",
        "    [changepoint_prior_scale, rmse, mae, mape]\n",
        "    \"\"\"\n",
        "    tuning_results = []\n",
        "\n",
        "    for cps in cps_values:\n",
        "        print(f\"  Testing changepoint_prior_scale = {cps}...\", end=' ', flush=True)\n",
        "\n",
        "        try:\n",
        "            model = Prophet(\n",
        "                changepoint_prior_scale = cps,\n",
        "                seasonality_prior_scale = 10.0,\n",
        "                yearly_seasonality      = True,\n",
        "                weekly_seasonality      = True,\n",
        "                daily_seasonality       = False,\n",
        "                interval_width          = 0.95\n",
        "            )\n",
        "\n",
        "            # suppress_all_output() silences the cmdstanpy Newton fallback messages\n",
        "            with suppress_all_output():\n",
        "                with warnings.catch_warnings():\n",
        "                    warnings.simplefilter(\"ignore\")\n",
        "                    model.fit(prophet_df)\n",
        "                    df_cv = cross_validation(\n",
        "                        model,\n",
        "                        initial      = initial,\n",
        "                        period       = period,\n",
        "                        horizon      = horizon,\n",
        "                        disable_tqdm = True\n",
        "                    )\n",
        "\n",
        "            # performance_metrics runs outside the suppressor so any real errors surface\n",
        "            df_perf = performance_metrics(df_cv, rolling_window=1)\n",
        "\n",
        "            tuning_results.append({\n",
        "                'changepoint_prior_scale': cps,\n",
        "                'rmse':  df_perf['rmse'].mean(),\n",
        "                'mae':   df_perf['mae'].mean(),\n",
        "                'mape':  df_perf['mape'].mean()\n",
        "            })\n",
        "\n",
        "            print(f\"✅  RMSE={tuning_results[-1]['rmse']:.4f}\")\n",
        "\n",
        "        except Exception as e:\n",
        "            print(f\"❌  Failed: {e}\")\n",
        "            continue\n",
        "\n",
        "    if not tuning_results:\n",
        "        raise RuntimeError(\n",
        "            \"All Prophet CV fits failed.\\n\"\n",
        "            \"Possible causes:\\n\"\n",
        "            \"  1. Prophet not installed correctly — try: pip install prophet\\n\"\n",
        "            \"  2. Dataset too short for the specified 'initial' window\\n\"\n",
        "            \"  3. Stan backend unavailable — try: pip install pystan==2.19.1.1\"\n",
        "        )\n",
        "\n",
        "    return pd.DataFrame(tuning_results).sort_values('rmse').reset_index(drop=True)\n",
        "\n",
        "\n",
        "# ─── Run tuning ───────────────────────────────────────────────────────────────\n",
        "cps_candidates = [0.001, 0.01, 0.05, 0.1, 0.3, 0.5]\n",
        "\n",
        "print(\"Tuning Prophet's changepoint_prior_scale via cross-validation...\")\n",
        "print(\"Initial window set to 365 days to cover full yearly seasonality cycle.\")\n",
        "print(\"-\" * 60)\n",
        "\n",
        "tuning_df = tune_prophet_changepoint(prophet_df, cps_candidates)\n",
        "\n",
        "print(\"-\" * 60)\n",
        "print(\"\\nTuning Results (sorted by RMSE):\")\n",
        "print(tuning_df.to_string(index=False))\n",
        "\n",
        "best_cps = float(tuning_df.iloc[0]['changepoint_prior_scale'])\n",
        "print(f\"\\n✅ Best changepoint_prior_scale = {best_cps}  (RMSE = {tuning_df.iloc[0]['rmse']:.4f})\")\n",
        "print(f\"   Interpretation: CPS={best_cps} balances trend flexibility with generalisation —\")\n",
        "print(f\"   too high risks overfitting the ~16 months of training data.\")"
      ]
