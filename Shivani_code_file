        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "# ARIMA Grid Search — Exhaustive search over p ∈ [0,8], d ∈ [0,2], q ∈ [0,8]\n",
        "# We use SARIMAX from statsmodels which is the standard robust ARIMA implementation\n",
        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "\n",
        "def arima_grid_search(series, p_range, d_range, q_range, verbose_every=50):\n",
        "    \"\"\"\n",
        "    Performs an exhaustive grid search over ARIMA(p,d,q) parameter combinations,\n",
        "    scoring each model with AIC. Returns a DataFrame of all results sorted by AIC.\n",
        "\n",
        "    Parameters:\n",
        "    -----------\n",
        "    series        : pd.Series — the original (undifferenced) time series\n",
        "    p_range       : range or list — candidate AR orders\n",
        "    d_range       : range or list — candidate integration orders\n",
        "    q_range       : range or list — candidate MA orders\n",
        "    verbose_every : int — print progress every N iterations\n",
        "\n",
        "    Returns:\n",
        "    --------\n",
        "    pd.DataFrame with columns: p, d, q, AIC, BIC  (sorted ascending by AIC)\n",
        "    \"\"\"\n",
        "    results = []\n",
        "    combos  = list(itertools.product(p_range, d_range, q_range))\n",
        "    total   = len(combos)\n",
        "\n",
        "    print(f\"Starting grid search: {total} combinations to evaluate...\")\n",
        "    print(f\"Parameter space: p ∈ {list(p_range)}, d ∈ {list(d_range)}, q ∈ {list(q_range)}\")\n",
        "    print(\"-\" * 60)\n",
        "\n",
        "    for i, (p, d, q) in enumerate(combos):\n",
        "\n",
        "        # Skip trivially invalid model (p=0, d=0, q=0 = white noise, not useful)\n",
        "        if p == 0 and d == 0 and q == 0:\n",
        "            continue\n",
        "\n",
        "        try:\n",
        "            # Fit ARIMA(p, d, q) — enforce_stationarity/invertibility set to False\n",
        "            # allows us to fit at boundary conditions without throwing errors\n",
        "            model = SARIMAX(\n",
        "                series,\n",
        "                order=(p, d, q),\n",
        "                enforce_stationarity=False,\n",
        "                enforce_invertibility=False,\n",
        "                trend='n'   # No deterministic trend term — let differencing handle it\n",
        "            )\n",
        "            fit = model.fit(disp=False, maxiter=200)\n",
        "\n",
        "            results.append({\n",
        "                'p': p, 'd': d, 'q': q,\n",
        "                'AIC': round(fit.aic, 4),\n",
        "                'BIC': round(fit.bic, 4)\n",
        "            })\n",
        "\n",
        "        except Exception:\n",
        "            # Some extreme parameter combinations may fail to converge\n",
        "            pass\n",
        "\n",
        "        # Progress reporting\n",
        "        if (i + 1) % verbose_every == 0:\n",
        "            best_so_far = min(results, key=lambda x: x['AIC']) if results else {}\n",
        "            print(f\"  [{i+1:>3}/{total}] Done. Best so far: \"\n",
        "                  f\"ARIMA{best_so_far.get('p','-'),best_so_far.get('d','-'),best_so_far.get('q','-')} \"\n",
        "                  f\"AIC={best_so_far.get('AIC','N/A')}\")\n",
        "\n",
        "    results_df = pd.DataFrame(results).sort_values('AIC').reset_index(drop=True)\n",
        "    print(\"-\" * 60)\n",
        "    print(f\"✅ Grid search complete. {len(results_df)} models successfully fitted.\")\n",
        "    return results_df\n",
        "\n",
        "# ─── Run the grid search ──────────────────────────────────────────────────────\n",
        "grid_results = arima_grid_search(\n",
