        "# ─── Load the CSV file ───────────────────────────────────────────────────────\n",
        "# The file uses a BOM character (utf-8-sig) at the start — we handle this with encoding parameter.\n",
        "# dayfirst=True is critical: dates are in DD/MM/YYYY format, not MM/DD/YYYY.\n",
        "\n",
        "df = pd.read_csv(\n",
        "    'oil_prices_2426.csv',\n",
        "    encoding='utf-8-sig',\n",
        "    parse_dates=['date'],\n",
        "    dayfirst=True,\n",
        "    index_col='date'\n",
        ")\n",
        "\n",
        "# ─── Rename column for convenience ───────────────────────────────────────────\n",
        "df.columns = ['price']\n",
        "\n",
        "# ─── Sort chronologically (safety step) ──────────────────────────────────────\n",
        "df.sort_index(inplace=True)\n",
        "\n",
        "# ─── Frequency inference ─────────────────────────────────────────────────────\n",
        "# Although the data is labelled 'daily', we set frequency to calendar days.\n",
        "# This matters for ARIMA forecasting to correctly project future dates.\n",
        "df = df.asfreq('D', method='ffill')   # forward-fill any calendar gaps (weekends etc.)\n",
        "\n",
        "print(\"=\" * 55)\n",
        "print(\"         DATASET OVERVIEW\")\n",
